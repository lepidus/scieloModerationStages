msgid "emails.sentToTypeModerationStage.name"
msgstr "Notificação de avanço na moderação para Pré-moderação de Tipo"

msgid "emails.sentToTypeModerationStage.description"
msgstr "Modelo de e-mail usado para notificar sobre o avanço de uma submissão para o estágio de Pré-moderação de Tipo."

msgid "emails.sentToTypeModerationStage.subject"
msgstr "Avanço na Moderação de Submissão"

msgid "emails.sentToTypeModerationStage.body"
msgstr ""
"Prezado(a) {$authorName},<br>\n"
"<br>\n"
"A sua submissão foi encaminhada para o estágio de Pré-Moderação de Tipo de Manuscrito e está passando por uma verificação"
" que avalia se se trata de uma pesquisa original com autores com antecedentes acadêmicos passível de aprovação automática.<br>\n"
"<br>\n"
"Para facilitar a moderação, informe um ORCID atualizado com a produção científica mais recente para ao menos um dos autores"
" cadastrados na submissão.<br>\n"
"<br>\n"
"Opcionalmente, você também pode informar um endosso para o preprint, caso possua.<br>\n"
"<br>\n"
"Para mais informações, recomendamos a leitura de nossas <a href=\"{$faqUrl}\">FAQs n°10 e 19</a>.<br>\n"
"<br>\n"


msgid "emails.sentToAreaModerationStage.name"
msgstr "Notificação de avanço na moderação para Moderação de Área"

msgid "emails.sentToAreaModerationStage.description"
msgstr "Modelo de e-mail usado para notificar sobre o avanço de uma submissão para o estágio de Moderação de Área."

msgid "emails.sentToAreaModerationStage.subject"
msgstr "Avanço na Moderação de Submissão"

msgid "emails.sentToAreaModerationStage.body"
msgstr ""
"Prezado(a) {$authorName},<br>\n"
"<br>\n"
"A sua submissão foi encaminhada para o estágio de Moderação de Área, onde está sendo moderada por um editor de periódico SciELO.<br>\n"
"<br>\n"
"Por favor, aguarde retorno da nossa equipe.<br>\n"
"<br>\n"
"Para mais informações, recomendamos a leitura da nossa <a href=\"{$faqUrl}\">FAQ n°19</a>.<br>\n"
"<br>\n"


msgid "emails.returnedToModerationStage.name"
msgstr "Notificação de retorno na moderação para um estágio anterior"

msgid "emails.returnedToModerationStage.description"
msgstr "Modelo de e-mail usado para notificar sobre o retorno de uma submissão para um estágio anterior de moderação."

msgid "emails.returnedToModerationStage.subject"
msgstr "Retorno na Moderação de Submissão"

msgid "emails.returnedToModerationStage.body"
msgstr ""
"Prezado(a) {$authorName},<br>\n"
"<br>\n"
"A sua submissão foi retornada para o estágio de {$moderationStageName}, onde passará por uma nova moderação.<br>\n"
"<br>\n"
"Por favor, aguarde retorno da nossa equipe.<br>\n"
"<br>\n"
"Para mais informações, recomendamos a leitura da nossa <a href=\"{$faqUrl}\">FAQ n°19</a>.<br>\n"
"<br>\n"
