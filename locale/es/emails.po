msgid "emails.sentToTypeModerationStage.name"
msgstr "Notificación de avance en la moderación para Pre-moderación de Tipo"

msgid "emails.sentToTypeModerationStage.description"
msgstr "Plantilla de correo electrónico utilizada para notificar sobre el avance de una publicación a la etapa de Pre-moderación de Tipo."

msgid "emails.sentToTypeModerationStage.subject"
msgstr "Avance en la Moderación de Publicación"

msgid "emails.sentToTypeModerationStage.body"
msgstr ""
"Estimado(a) {$authorName},<br>\n"
"<br>\n"
"Su publicación ha sido enviada a la etapa de Pre-Moderación de Tipo de Manuscrito y está siendo sometida a una verificación"
" que evalúa si se trata de una investigación original con autores con antecedentes académicos susceptible de aprobación automática.<br>\n"
"<br>\n"
"Para facilitar la moderación, por favor proporcione un ORCID actualizado con la producción científica más reciente de al menos uno de los autores"
" registrados en la publicación.<br>\n"
"<br>\n"
"Opcionalmente, también puede proporcionar un endoso para el preprint, si dispone de uno.<br>\n"
"<br>\n"
"Para más información, le recomendamos la lectura de nuestras <a href=\"{$faqUrl}\">FAQs n°10 y 19.</a><br>\n"
"<br>\n"


msgid "emails.sentToAreaModerationStage.name"
msgstr "Notificación de avance en la moderación para Moderación del Área"

msgid "emails.sentToAreaModerationStage.description"
msgstr "Plantilla de correo electrónico utilizada para notificar sobre el avance de una publicación a la etapa de Moderación del Área."

msgid "emails.sentToAreaModerationStage.subject"
msgstr "Avance en la Moderación de Publicación"

msgid "emails.sentToAreaModerationStage.body"
msgstr ""
"Estimado(a) {$authorName},<br>\n"
"<br>\n"
"Su artículo ha sido remitido a la fase de Moderación del Área, donde está siendo revisado por un editor de una revista de SciELO.<br>\n"
"<br>\n"
"Por favor, espere a recibir noticias de nuestro equipo.<br>\n"
"<br>\n"
"Para más información, le recomendamos la lectura de nuestra <a href=\"{$faqUrl}\">FAQ n°19.</a><br>\n"
"<br>\n"