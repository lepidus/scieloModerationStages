msgid "emails.sentToTypeModerationStage.name"
msgstr "Notification of Advancement in Moderation to Type Pre-moderation"

msgid "emails.sentToTypeModerationStage.description"
msgstr "Email template used to notify about the advancement of a submission to the Type Pre-moderation."

msgid "emails.sentToTypeModerationStage.subject"
msgstr "Advancement in Submission Moderation"

msgid "emails.sentToTypeModerationStage.body"
msgstr ""
"Dear {$authorName},<br>\n"
"<br>\n"
"Your submission has been forwarded to the Manuscript Type Pre-Moderation stage and is undergoing a review"
" that assesses whether it is an original research by authors with academic backgrounds eligible for automatic approval.<br>\n"
"<br>\n"
"To facilitate moderation, please provide an updated ORCID with the most recent scientific output for at least one of the authors"
" registered in the submission.<br>\n"
"<br>\n"
"Optionally, you may also provide an endorsement for the preprint, if you have one.<br>\n"
"<br>\n"
"For more information, we recommend reading our <a href=\"{$faqUrl}\">FAQs #10 and #19.</a><br>\n"
"<br>\n"


msgid "emails.sentToAreaModerationStage.name"
msgstr "Notification of Advancement in Moderation to Area Moderation"

msgid "emails.sentToAreaModerationStage.description"
msgstr "Email template used to notify about the advancement of a submission to the Area Moderation."

msgid "emails.sentToAreaModerationStage.subject"
msgstr "Advancement in Submission Moderation"

msgid "emails.sentToAreaModerationStage.body"
msgstr ""
"Dear {$authorName},<br>\n"
"<br>\n"
"Your submission has been forwarded to the Area Moderation stage, where it is being reviewed by a SciELO journal editor.<br>\n"
"<br>\n"
"Please wait for a response from our team.<br>\n"
"<br>\n"
"For more information, we recommend reading our <a href=\"{$faqUrl}\">FAQ #19.</a><br>\n"
"<br>\n"